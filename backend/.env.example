# GitHub token (optional but recommended — raises rate limit from 60 to 5000 req/hr)
# Get one at https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here

# Embedding provider: local | gemini | openai
# local  — no API key needed, downloads ~550MB model on first run, runs on CPU
# gemini — free tier: 1500 req/day, fast, no local model needed
# openai — paid, fastest, best quality
EMBEDDING_PROVIDER=local

# Gemini API key (only needed if EMBEDDING_PROVIDER=gemini)
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API key (only needed if EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
